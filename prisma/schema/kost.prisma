model Kost {
  id      String @id @default(uuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name        String
  description String?

  type  KostType

  address  String
  city     String
  province String?

  latitude  Float?
  longitude Float?

  thumbnail String?

  rooms Room[]

  status KostStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("kosts")
}

enum KostType {
  MALE
  FEMALE
  MIXED
}

enum KostStatus {
  PENDING
  ACTIVE
  INACTIVE
  BANNED
}
