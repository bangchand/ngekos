server {
    listen 80;
    server_name api.domainkamu.com; # Ganti dengan domain atau IP server kamu

    # Pengaturan log (opsional tapi disarankan)
    access_log /var/log/nginx/express_api_access.log;
    error_log /var/log/nginx/express_api_error.log;

    location / {
        # Forward request ke Node.js (Express) yang berjalan di port 3000
        proxy_pass http://localhost:3000;
        
        # Headers penting agar backend mengenali request asli
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Bypass cache (karena ini API)
        proxy_cache_bypass $http_upgrade;
    }
}
