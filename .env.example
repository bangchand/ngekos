# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# Replace with your own database connection string (PostgreSQL, MySQL, SQLite, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/express_ts_db?schema=public"

# Security Configurations
JWT_SECRET="your_jwt_secret_key_should_be_at_least_32_characters_long"
JWT_EXPIRES_IN="1d"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX=100
